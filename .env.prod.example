# Production environment template for Timeweb VPS
# Copy to .env and fill in real values

# Database
DATABASE_URL=postgres://sellico:CHANGE_ME@postgres:5432/sellico?sslmode=disable
POSTGRES_USER=sellico
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=sellico

# Redis
REDIS_URL=redis://:CHANGE_ME@redis:6379/0
REDIS_PASSWORD=CHANGE_ME

# Auth
JWT_SECRET=CHANGE_ME_min_32_chars_long_random_string
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=168h

# Encryption (32-byte hex key)
ENCRYPTION_KEY=CHANGE_ME_32_byte_hex

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
APP_VERSION=1.0.0

# Wildberries API
WB_API_BASE_URL=https://advert-api.wildberries.ru
WB_API_RATE_LIMIT=10

# Export
EXPORT_STORAGE_PATH=/app/exports

# Worker Schedules (Asynq cron syntax: @every 30m, @every 1h, etc.)
SYNC_INTERVAL=@every 1h
RECOMMENDATION_INTERVAL=@every 2h

# CORS
CORS_ALLOW_ORIGINS=https://sellico.ru,https://your-domain.com

# Rate Limiting
RATE_LIMIT_RPS=20
RATE_LIMIT_BURST=40

# Monitoring
GRAFANA_ADMIN_PASSWORD=CHANGE_ME
GRAFANA_ROOT_URL=https://your-domain.com:3000

# Docker images (set by CD pipeline)
API_IMAGE=ghcr.io/panfiloveshow/sellico-ads-intelligence-backend-api:latest
WORKER_IMAGE=ghcr.io/panfiloveshow/sellico-ads-intelligence-backend-worker:latest

# Sellico
SELLICO_API_BASE_URL=https://sellico.ru/api

# Logging
LOG_LEVEL=info
