# Database
DATABASE_URL=postgres://sellico:sellico@localhost:5432/sellico?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET=your-jwt-secret-min-32-chars-long
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=168h

# Encryption
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
APP_VERSION=dev

# Wildberries API
WB_API_BASE_URL=https://advert-api.wildberries.ru
WB_API_RATE_LIMIT=10

# Ads Read service per-query data caps. Tuned during the OOM incident (Apr 2026)
# to keep API memory under 1G; raise cautiously and monitor RSS.
ADS_READ_ENTITY_LIMIT=5000
ADS_READ_STATS_LIMIT=20000

# WB Catalog Parser
WB_PARSER_MIN_DELAY=500ms
WB_PARSER_PROXIES=

# Export
EXPORT_STORAGE_PATH=./exports

# Worker Schedules (Asynq cron syntax)
SYNC_INTERVAL=@every 1h
RECOMMENDATION_INTERVAL=@every 2h
BID_AUTOMATION_INTERVAL=@every 15m

# CORS (comma-separated origins, empty = allow all)
CORS_ALLOW_ORIGINS=

# Rate Limiting (per-user token bucket)
RATE_LIMIT_RPS=20
RATE_LIMIT_BURST=40

# Monitoring
GRAFANA_ADMIN_PASSWORD=sellico

# Sellico service-account API (financial-dashboard/rules.md pattern).
# One of the two auth paths is required to enable integration auto-discovery
# and the GET /check-permission middleware. Both empty disables the integration.
#   SELLICO_API_TOKEN: long-lived static bearer (preferred in prod)
#   SELLICO_EMAIL + SELLICO_PASSWORD: backend auto-logs-in at first use
SELLICO_API_BASE_URL=https://sellico.ru/api
SELLICO_API_TOKEN=
SELLICO_EMAIL=
SELLICO_PASSWORD=

# Logging
LOG_LEVEL=info
