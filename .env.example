# Database
DATABASE_URL=postgres://sellico:sellico@localhost:5432/sellico?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET=your-jwt-secret-min-32-chars-long
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=168h

# Encryption
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
APP_VERSION=dev

# Wildberries API
WB_API_BASE_URL=https://advert-api.wildberries.ru
WB_API_RATE_LIMIT=10

# Ads Read service per-query data caps. Tuned during the OOM incident (Apr 2026)
# to keep API memory under 1G; raise cautiously and monitor RSS.
ADS_READ_ENTITY_LIMIT=5000
ADS_READ_STATS_LIMIT=20000

# WB Catalog Parser
WB_PARSER_MIN_DELAY=500ms
WB_PARSER_PROXIES=

# Export
EXPORT_STORAGE_PATH=./exports

# Email reports (optional; SMTP_HOST empty disables email delivery)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Sellico Ads Intelligence
SMTP_TIMEOUT=10s

# Worker Schedules (Asynq cron syntax)
SYNC_INTERVAL=@every 1h
RECOMMENDATION_INTERVAL=@every 2h
BID_AUTOMATION_INTERVAL=@every 15m
# Repricer (WB price management)
REPRICER_INTERVAL=@every 1h
REPRICER_POLL_INTERVAL=@every 5m
REPRICER_SCHEDULE_INTERVAL=@every 15m

# CORS (comma-separated origins). Empty = no cross-origin requests allowed.
# For local dev set e.g. http://localhost:5173; use "*" to allow any origin.
CORS_ALLOW_ORIGINS=

# Rate Limiting (per-user token bucket)
RATE_LIMIT_RPS=20
RATE_LIMIT_BURST=40

# Monitoring
GRAFANA_ADMIN_PASSWORD=sellico

# Sellico service-account API (financial-dashboard/rules.md pattern).
# One of the two auth paths is required to enable integration auto-discovery
# and the GET /check-permission middleware. Both empty disables the integration.
#   SELLICO_API_TOKEN: long-lived static bearer (preferred in prod)
#   SELLICO_EMAIL + SELLICO_PASSWORD: backend auto-logs-in at first use
SELLICO_API_BASE_URL=https://sellico.ru/api
SELLICO_UNIT_ECONOMICS_READINESS_PATH=
# Repricer cost bridge: products-backend endpoint returning cost/commission/tax
# by nmID. PRODUCTS_API_TOKEN is a shared secret that must match the
# products-backend REPRICER_SERVICE_TOKEN. Empty PRODUCTS_API_TOKEN disables the
# bridge (margin-floor then needs manual /product-economics/import).
SELLICO_UNIT_ECONOMICS_EXPORT_PATH=/products/unit-economics/export
PRODUCTS_API_BASE_URL=https://products.sellico.ru/api
PRODUCTS_API_TOKEN=
PRODUCTS_UNIT_ECONOMICS_READINESS_PATH=/products/unit-economics/readiness
PRODUCTS_UNIT_ECONOMICS_MAX_AGE=72h
SELLICO_API_TOKEN=
SELLICO_EMAIL=
SELLICO_PASSWORD=

# Logging
LOG_LEVEL=info
